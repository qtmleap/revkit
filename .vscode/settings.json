{
  "gitdoc.ai.customInstructions": "Generate a commit message in English following the Conventional Commits specification and `commitlint` rules. Use the format `<type>(<scope>): <short description>` and choose `<type>` from `build`, `ci`, `docs`, `feat`, `fix`, `perf`, `chore`, `refactor`, `revert`, `format`, `test`. Limit `<short description>` to 72 characters. If `<short description>` starts with an English word, it must be in lowercase.",
  "gitdoc.ai.enabled": true,
  "gitdoc.ai.model": "gpt-4o",
  "gitdoc.autoPull": "onPush",
  "gitdoc.commitValidationLevel": "none",
  "gitdoc.enabled": true,
  "gitdoc.excludeBranches": [
    "develop",
    "master"
  ],
  "gitdoc.pushMode": "push",
  "gitdoc.timeZone": "Asia/Tokyo",
  "gitlens.ai.generateCommitMessage.customInstructions": "Generate a commit message in English following the Conventional Commits specification and `commitlint` rules. Use the format `<type>(<scope>): <short description>` and choose `<type>` from `build`, `ci`, `docs`, `feat`, `fix`, `perf`, `chore`, `refactor`, `revert`, `format`, `test`. Limit `<short description>` to 72 characters. If `<short description>` starts with an English word, it must be in lowercase.",
  "remote.localPortHost": "allInterfaces",
  "python.terminal.activateEnvironment": false,
  "files.exclude": {
    "**/__pycache__": true,
    "**/.venv": true,
    "**/.ruff_cache": true,
    "**/cache": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/.git": true,
    "**/node_modules": true,
    "**.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/target": true,
    "**/dist": true,
    "**/.next": true,
    "**/.nuxt": true,
    "**/.svelte-kit": true,
    "**/.turbo": true,
    "**/.wrangler": true,
    "**/.cache": true,
    "**/.parcel-cache": true,
    "**/coverage": true,
    "**/.nyc_output": true,
    "**/.tanstack": true
  },
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.tabSize": 2,
  "editor.rulers": [
    100,
    120
  ],
  "editor.renderWhitespace": "boundary",
  "editor.guides.bracketPairs": "active",
  "editor.stickyScroll.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.autoSave": "onFocusChange",
  "files.watcherExclude": {
    "**/.git/objectsnode_modules.venvtargetdist.next.wranglernode_modules": true,
    "**/dist": true,
    "**/target": true,
    "**/.venv": true,
    "**/coverage": true,
    "**routeTree.gen.ts": true,
    "**/bun.lock": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/yarn.lock": true,
    "**/uv.lock": true,
    "**/poetry.lock": true,
    "**/Cargo.lock": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, pnpm-lock.yaml, yarn.lock, bun.lock, bun.lockb, .npmrc, .nvmrc, .node-version, tsconfig*.json, biome.json, .biomeignore, .prettier*, .eslintrc*, vite.config*, vitest.config*, wrangler.toml, wrangler.jsonc",
    "pyproject.toml": "uv.lock, poetry.lock, requirements*.txt, .python-version, ruff.toml, .ruff.toml, mypy.ini",
    "Cargo.toml": "Cargo.lock, rust-toolchain*, rustfmt.toml, .cargo/config.toml",
    "Package.swift": "Package.resolved, .swift-version, .swiftformat",
    "Dockerfile": "compose.yaml, compose.*.yaml, docker-compose.yml, docker-compose.*.yml, .dockerignore",
    ".gitignore": ".gitattributes",
    "README.md": "CHANGELOG.md, LICENSE*, CONTRIBUTING.md, CODE_OF_CONDUCT.md, SECURITY.md, AUTHORS*",
    "*.ts": "$(capture).test.ts, $(capture).spec.ts, $(capture).d.ts",
    "*.tsx": "$(capture).test.tsx, $(capture).spec.tsx, $(capture).module.css"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.pruneOnFetch": true,
  "git.branchProtection": [
    "main",
    "master",
    "develop"
  ],
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[markdown]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false
  },
  "[swift]": {
    "editor.defaultFormatter": "swiftlang.swift-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 4
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "swift.path": "/usr/bin/swift",
  "swift.buildPath": ".build",
  "swift.diagnostics": true,
  "python.defaultInterpreterPath": "/home/vscode/app/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",
  "ruff.importStrategy": "fromEnvironment",
  "ruff.nativeServer": "on"
}
